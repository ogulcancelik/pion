{
  "name": "pion",
  "version": "0.1.0",
  "description": "Simple messaging bridge for pi-agent",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch src/daemon.ts",
    "start": "bun run src/daemon.ts",
    "daemon": "bun run src/daemon.ts",
    "whatsapp:pair": "bun run scripts/whatsapp-pair.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src test",
    "lint:fix": "biome check --write src test",
    "format": "biome format --write src test",
    "monitor": "bun run src/tui/monitor.ts"
  },
  "dependencies": {
    "@mariozechner/pi-agent-core": "0.58.4",
    "@mariozechner/pi-ai": "0.58.4",
    "@mariozechner/pi-coding-agent": "0.58.4",
    "@mariozechner/pi-tui": "0.58.4",
    "@whiskeysockets/baileys": "^7.0.0-rc.9",
    "grammy": "^1.39.2",
    "markdown-it": "^14.1.0",
    "qrcode-terminal": "^0.12.0",
    "yaml": "^2.7.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/bun": "^1.3.6",
    "@types/markdown-it": "^14.1.2",
    "typescript": "^5.9.3"
  }
}
